# ── Required: Alem AI keys (provided to eval harness) ──────────────────────
# LLM (chat completions) — used for fact extraction and contradiction resolution
ALEM_API_KEY=sk-your-llm-key-here
ALEM_LLM_BASE_URL=https://llm.alem.ai/v1
ALEM_LLM_MODEL=alemllm

# Embeddings — used to vectorize memories and queries (dim=1024)
EMBED_API_KEY=sk-your-embed-key-here
EMBED_BASE_URL=https://llm.alem.ai/v1
EMBED_MODEL=text-1024

# Reranker — Cohere-compatible cross-encoder for final ranking
RERANK_API_KEY=your-rerank-key-here
RERANK_BASE_URL=https://llm.alem.ai/v1
RERANK_MODEL=reranker

# ── Optional: service auth ──────────────────────────────────────────────────
# If set, all endpoints require: Authorization: Bearer <MEMORY_AUTH_TOKEN>
# If unset, the Authorization header is ignored.
MEMORY_AUTH_TOKEN=

# ── Database (defaults match docker-compose) ───────────────────────────────
DATABASE_URL=postgresql://memory:memory@db:5432/memory

# ── Service config ─────────────────────────────────────────────────────────
LOG_LEVEL=INFO
